# =========================
# Frontend (Next.js)
# =========================

# Backend API base URL
NEXT_PUBLIC_API_URL=http://localhost:4001

# Frontend public URL (used to generate links, e.g. unilinks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase client config
NEXT_PUBLIC_API_KEY_URL=your-firebase-api-key
NEXT_PUBLIC_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_PROJECT_ID=your-project-id
NEXT_PUBLIC_APP_ID=your-firebase-app-id

# Production examples:
# NEXT_PUBLIC_API_URL=https://api.resilio-life.com
# NEXT_PUBLIC_APP_URL=https://resilio-life.vercel.app
